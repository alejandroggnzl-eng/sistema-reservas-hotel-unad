    "# ── Clase base ──\n",
    "class HotelException(Exception):\n",
    "    \"\"\"Excepción base del sistema hotelero. Todas las excepciones del sistema heredan de esta clase.\"\"\"\n",
    "    pass\n",
    "\n",
    "# ── Excepción: habitación no disponible ──\n",
    "class HabitacionNoDisponibleError(HotelException):\n",
    "    \"\"\"Se lanza cuando la habitación solicitada ya está ocupada.\"\"\"\n",
    "    def __init__(self, numero_habitacion):\n",
    "        self.numero_habitacion = numero_habitacion\n",
    "        super().__init__(f\"La habitación {numero_habitacion} no está disponible.\")\n",
    "\n",
    "# ── Excepción: datos de reserva inválidos ──\n",
    "class ReservaInvalidaError(HotelException):\n",
    "    \"\"\"Se lanza cuando los datos de la reserva no cumplen las reglas de negocio.\"\"\"\n",
    "    def __init__(self, motivo):\n",
    "        super().__init__(f\"Reserva inválida: {motivo}\")\n",
    "\n",
    "# ── Excepción: cliente no registrado ──\n",
    "class ClienteNoEncontradoError(HotelException):\n",
    "    \"\"\"Se lanza cuando el cliente no existe en el sistema.\"\"\"\n",
    "    def __init__(self, nombre_cliente):\n",
    "        super().__init__(f\"Cliente '{nombre_cliente}' no encontrado en el sistema.\")\n",
    "\n",
    "# ── Excepción: servicio no operativo ──\n",
    "class ServicioNoDisponibleError(HotelException):\n",
    "    \"\"\"Se lanza cuando el servicio del hotel no está operativo.\"\"\"\n",
    "    def __init__(self, servicio):\n",
    "        super().__init__(f\"El servicio '{servicio}' no está disponible en este momento.\")\n",
    "\n",
    "# ── Excepción: fallo de pago ──\n",
    "class PagoFallidoError(HotelException):\n",
    "    \"\"\"Se lanza cuando el procesamiento del pago falla.\"\"\"\n",
    "    def __init__(self, monto):\n",
    "        super().__init__(f\"Error al procesar el pago de ${monto:.2f}.\")\n",
    "\n",
    "print(\"✅ Excepciones personalizadas definidas:\")\n",
    "print(\"   HotelException (base)\")\n",
    "print(\"   ├── HabitacionNoDisponibleError\")\n",
    "print(\"   ├── ReservaInvalidaError\")\n",
    "print(\"   ├── ClienteNoEncontradoError\")\n",
    "print(\"   ├── ServicioNoDisponibleError\")\n",
    "print(\"   └── PagoFallidoError\")"
   ]
