     "text": [
      "✅ Excepciones personalizadas definidas:\n",
      "   HotelException (base)\n",
      "   ├── HabitacionNoDisponibleError\n",
      "   ├── ReservaInvalidaError\n",
      "   ├── ClienteNoEncontradoError\n",
