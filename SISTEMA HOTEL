    "## 4. Clase Principal: SistemaHotel\n",
    "Implementa el manejo completo de excepciones con `try/except`, `try/except/else`, `try/finally` y encadenamiento de excepciones.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e5a046a0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Clase SistemaHotel definida con todos los métodos."
     ]
    }
   ],
   "source": [
    "class SistemaHotel:\n",
    "    \"\"\"Sistema principal del hotel con manejo robusto de excepciones.\"\"\"\n",
    "\n",
    "    SERVICIOS_DISPONIBLES     = [\"spa\", \"restaurante\", \"gimnasio\", \"piscina\"]\n",
    "    SERVICIOS_NO_DISPONIBLES  = [\"sala_conferencias\", \"bar_nocturno\"]\n",
    "\n",
    "    def __init__(self):\n",
    "        # Inventario de habitaciones del hotel\n",
    "        self.habitaciones = {\n",
    "            101: Habitacion(101, \"simple\", 80),\n",
    "            102: Habitacion(102, \"simple\", 80),\n",
    "            201: Habitacion(201, \"doble\", 150),\n",
    "            202: Habitacion(202, \"doble\", 150),\n",
    "            301: Habitacion(301, \"suite\", 300),\n",
    "        }\n",
    "        # Lista de clientes registrados en el sistema\n",
    "        self.clientes_registrados = [\n",
    "            \"Ana Torres\", \"Luis Pérez\", \"María Gómez\", \"Carlos Ruiz\", \"Laura Díaz\"\n",
    "        ]\n",
    "        self.reservas = []\n",
    "        logger.info(\"Sistema de Reservas de Hotel iniciado correctamente.\")\n",
    "\n",
    "    def _validar_fechas(self, fecha_entrada, fecha_salida):\n",
    "        \"\"\"Valida que las fechas de la reserva sean lógicamente correctas.\"\"\"\n",
    "        if fecha_entrada >= fecha_salida:\n",
    "            raise ReservaInvalidaError(\"La fecha de entrada debe ser anterior a la de salida.\")\n",
    "        if fecha_entrada < datetime.today().replace(hour=0, minute=0, second=0, microsecond=0):\n",
    "            raise ReservaInvalidaError(\"No se pueden hacer reservas en fechas pasadas.\")\n",
    "\n",
    "    def _validar_cliente(self, nombre_cliente):\n",
    "        \"\"\"Verifica que el cliente esté registrado en el sistema.\"\"\"\n",
    "        if nombre_cliente not in self.clientes_registrados:\n",
    "            raise ClienteNoEncontradoError(nombre_cliente)\n",
    "\n",
    "    def _procesar_pago(self, monto):\n",
    "        \"\"\"Simula el procesamiento de pago. Falla si el monto es inválido.\"\"\"\n",
    "        if monto <= 0:\n",
    "            raise PagoFallidoError(monto)\n",
    "        if monto == 999:  # Caso especial para prueba de encadenamiento\n",
    "            raise PagoFallidoError(monto)\n",
    "\n",
    "    def hacer_reserva(self, nombre_cliente, numero_habitacion, fecha_entrada, fecha_salida):\n",
    "        \"\"\"\n",
    "        Realiza una reserva con manejo completo de excepciones.\n",
    "        Demuestra: try/except, try/except/else, try/finally y encadenamiento.\n",
    "        \"\"\"\n",
    "        logger.info(f\"Intentando reserva: cliente={nombre_cliente}, hab={numero_habitacion}\")\n",
    "        try:\n",
    "            # Paso 1: Validar cliente registrado\n",
    "            self._validar_cliente(nombre_cliente)\n",
    "\n",
    "            # Paso 2: Validar existencia y disponibilidad de habitación\n",
    "            if numero_habitacion not in self.habitaciones:\n",
    "                raise ReservaInvalidaError(f\"La habitación {numero_habitacion} no existe.\")\n",
    "            habitacion = self.habitaciones[numero_habitacion]\n",
    "            if not habitacion.disponible:\n",
    "                raise HabitacionNoDisponibleError(numero_habitacion)\n",
    "\n",
    "            # Paso 3: Validar fechas\n",
    "            self._validar_fechas(fecha_entrada, fecha_salida)\n",
    "\n",
    "            # Paso 4: Crear reserva y procesar pago\n",
    "            nueva_reserva = Reserva(nombre_cliente, habitacion, fecha_entrada, fecha_salida)\n",
    "            try:\n",
    "                self._procesar_pago(nueva_reserva.total)\n",
    "            except PagoFallidoError as e:\n",
    "                raise ReservaInvalidaError(\"Fallo en el pago\") from e  # ← Encadenamiento\n",
    "\n",
    "        except (HabitacionNoDisponibleError, ReservaInvalidaError,\n",
    "                ClienteNoEncontradoError) as e:\n",
    "            # Captura todos los errores de negocio\n",
    "            logger.error(f\"Error al hacer reserva: {e}\")\n",
    "            print(f\"  ❌ ERROR: {e}\")\n",
    "            return None\n",
    "\n",
    "        except Exception as e:\n",
    "            # Captura errores inesperados\n",
    "            logger.critical(f\"Error inesperado: {e}\")\n",
    "            print(f\"  ❌ ERROR INESPERADO: {e}\")\n",
    "            return None\n",
    "\n",
    "        else:\n",
    "            # Se ejecuta SOLO si no hubo ninguna excepción\n",
    "            habitacion.disponible = False\n",
    "            self.reservas.append(nueva_reserva)\n",
    "            logger.info(f\"Reserva exitosa: {nueva_reserva}\")\n",
    "            print(f\"  ✅ RESERVA CONFIRMADA: {nueva_reserva}\")\n",
    "            return nueva_reserva\n",
    "\n",
    "        finally:\n",
    "            # SIEMPRE se ejecuta, haya o no excepción\n",
    "            logger.debug(f\"Proceso de reserva finalizado para: {nombre_cliente}\")\n",
    "\n",
    "    def cancelar_reserva(self, id_reserva):\n",
    "        \"\"\"Cancela una reserva existente y libera la habitación.\"\"\"\n",
    "        logger.info(f\"Intentando cancelar reserva #{id_reserva}\")\n",
    "        try:\n",
    "            reserva = next((r for r in self.reservas if r.id == id_reserva), None)\n",
    "            if reserva is None:\n",
    "                raise ReservaInvalidaError(f\"No existe la reserva con ID {id_reserva}.\")\n",
    "            self.reservas.remove(reserva)\n",
    "            self.habitaciones[reserva.habitacion.numero].disponible = True\n",
    "            logger.info(f\"Reserva #{id_reserva} cancelada correctamente.\")\n",
    "            print(f\"  ✅ Reserva #{id_reserva} cancelada. Habitación liberada.\")\n",
    "        except ReservaInvalidaError as e:\n",
    "            logger.error(f\"Error al cancelar: {e}\")\n",
    "            print(f\"  ❌ ERROR: {e}\")\n",
    "        finally:\n",
    "            logger.debug(f\"Proceso de cancelación para reserva #{id_reserva} finalizado.\")\n",
    "\n",
    "    def solicitar_servicio(self, nombre_cliente, servicio):\n",
    "        \"\"\"Solicita un servicio adicional del hotel para un cliente.\"\"\"\n",
    "        logger.info(f\"Solicitud de servicio: cliente={nombre_cliente}, servicio={servicio}\")\n",
    "        try:\n",
    "            self._validar_cliente(nombre_cliente)\n",
    "            if servicio in self.SERVICIOS_NO_DISPONIBLES:\n",
    "                raise ServicioNoDisponibleError(servicio)\n",
    "            if servicio not in self.SERVICIOS_DISPONIBLES:\n",
    "                raise ReservaInvalidaError(f\"El servicio '{servicio}' no existe.\")\n",
    "            logger.info(f\"Servicio '{servicio}' asignado a {nombre_cliente}.\")\n",
    "            print(f\"  ✅ Servicio '{servicio}' confirmado para {nombre_cliente}.\")\n",
    "        except (ServicioNoDisponibleError, ClienteNoEncontradoError,\n",
    "                ReservaInvalidaError) as e:\n",
    "            logger.error(f\"Error en servicio: {e}\")\n",
    "            print(f\"  ❌ ERROR: {e}\")\n",
    "        finally:\n",
    "            logger.debug(f\"Solicitud de servicio finalizada para {nombre_cliente}.\")\n",
    "\n",
    "    def mostrar_habitaciones(self):\n",
    "        \"\"\"Muestra el estado actual de todas las habitaciones del hotel.\"\"\"\n",
    "        print(\"\\n  === ESTADO FINAL DE HABITACIONES ===\")\n",
    "        for hab in self.habitaciones.values():\n",
    "            print(f\"  {hab}\")\n",
    "        logger.info(\"Estado de habitaciones consultado.\")\n",
    "\n",
    "print(\"✅ Clase SistemaHotel definida con todos los métodos.\")"
   ]
