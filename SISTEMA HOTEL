    "class Habitacion:\n",
    "    \"\"\"Representa una habitación del hotel con su estado de disponibilidad.\"\"\"\n",
    "    def __init__(self, numero, tipo, precio_noche):\n",
    "        self.numero = numero          # Número identificador de la habitación\n",
    "        self.tipo = tipo              # Tipo: simple, doble, suite\n",
    "        self.precio_noche = precio_noche  # Precio por noche en dólares\n",
    "        self.disponible = True        # True = libre, False = ocupada\n",
    "\n",
    "    def __str__(self):\n",
    "        estado = \"Disponible ✅\" if self.disponible else \"Ocupada ❌\"\n",
    "        return f\"Hab. {self.numero} ({self.tipo}) - ${self.precio_noche}/noche - {estado}\"\n",
    "\n",
    "\n",
    "class Reserva:\n",
    "    \"\"\"Representa una reserva de hotel con cálculo automático del total.\"\"\"\n",
    "    contador = 1  # Identificador autoincremental de reservas\n",
    "\n",
    "    def __init__(self, cliente, habitacion, fecha_entrada, fecha_salida):\n",
    "        self.id = Reserva.contador\n",
    "        Reserva.contador += 1\n",
    "        self.cliente = cliente\n",
    "        self.habitacion = habitacion\n",
    "        self.fecha_entrada = fecha_entrada\n",
    "        self.fecha_salida = fecha_salida\n",
    "        noches = (fecha_salida - fecha_entrada).days  # Calcula noches automáticamente\n",
    "        self.total = noches * habitacion.precio_noche # Total = noches × precio\n",
    "\n",
    "    def __str__(self):\n",
    "        return (f\"Reserva #{self.id} | Cliente: {self.cliente} | \"\n",
    "                f\"Hab. {self.habitacion.numero} | \"\n",
    "                f\"Entrada: {self.fecha_entrada.strftime('%d/%m/%Y')} | \"\n",
    "                f\"Salida: {self.fecha_salida.strftime('%d/%m/%Y')} | \"\n",
    "                f\"Total: ${self.total:.2f}\")\n",
    "\n",
    "print(\"✅ Clases Habitacion y Reserva definidas correctamente.\")"
   ]
